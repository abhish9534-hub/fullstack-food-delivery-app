{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "customer"] },
        "address": { "type": "string" },
        "phone": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Restaurant": {
      "title": "Restaurant",
      "description": "Restaurant details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "rating": { "type": "number" },
        "deliveryTime": { "type": "string" },
        "categories": { "type": "array", "items": { "type": "string" } },
        "address": { "type": "string" },
        "ownerId": { "type": "string" }
      },
      "required": ["name", "image", "ownerId"]
    },
    "MenuItem": {
      "title": "MenuItem",
      "description": "Menu item for a restaurant",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "restaurantId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "isAvailable": { "type": "boolean" }
      },
      "required": ["restaurantId", "name", "price"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "restaurantId": { "type": "string" },
        "restaurantName": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "menuItemId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "preparing", "out-for-delivery", "delivered"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "deliveryAddress": { "type": "string" }
      },
      "required": ["customerId", "restaurantId", "items", "totalAmount", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/restaurants/{restaurantId}": {
      "schema": "Restaurant",
      "description": "Restaurant listings"
    },
    "/restaurants/{restaurantId}/menuItems/{menuItemId}": {
      "schema": "MenuItem",
      "description": "Menu items for a restaurant"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    }
  }
}
