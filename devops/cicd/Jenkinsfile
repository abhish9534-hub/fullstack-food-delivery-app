pipeline {
    agent any

    environment {
        AWS_REGION = 'us-east-1'
        ECR_REGISTRY = '123456789012.dkr.ecr.us-east-1.amazonaws.com'
        FRONTEND_REPO = 'ecommerce-frontend'
        BACKEND_REPO = 'ecommerce-backend'
        IMAGE_TAG = "${env.BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Static Code Analysis') {
            steps {
                script {
                    // Assuming SonarQube is configured in Jenkins
                    // withSonarQubeEnv('SonarQube') {
                    //     sh 'npm install && npm run lint'
                    // }
                    echo 'Running SonarQube Scan...'
                }
            }
        }

        stage('Dependency Scan') {
            steps {
                echo 'Running OWASP Dependency Check...'
                // dependencyCheck additionalArguments: '--format HTML --project ecommerce', odcInstallation: 'Dependency-Check'
            }
        }

        stage('Build & Scan Images') {
            steps {
                script {
                    // Build Frontend
                    sh "docker build -t ${ECR_REGISTRY}/${FRONTEND_REPO}:${IMAGE_TAG} -f devops/docker/frontend.Dockerfile ."
                    
                    // Scan with Trivy
                    sh "trivy image --exit-code 0 --severity HIGH,CRITICAL ${ECR_REGISTRY}/${FRONTEND_REPO}:${IMAGE_TAG}"
                    
                    // Build Backend
                    sh "docker build -t ${ECR_REGISTRY}/${BACKEND_REPO}:${IMAGE_TAG} -f devops/docker/backend.Dockerfile ."
                    
                    // Scan with Trivy
                    sh "trivy image --exit-code 0 --severity HIGH,CRITICAL ${ECR_REGISTRY}/${BACKEND_REPO}:${IMAGE_TAG}"
                }
            }
        }

        stage('Push to ECR') {
            steps {
                script {
                    sh "aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${ECR_REGISTRY}"
                    sh "docker push ${ECR_REGISTRY}/${FRONTEND_REPO}:${IMAGE_TAG}"
                    sh "docker push ${ECR_REGISTRY}/${BACKEND_REPO}:${IMAGE_TAG}"
                }
            }
        }

        stage('Deploy to EKS') {
            steps {
                script {
                    sh "aws eks update-kubeconfig --region ${AWS_REGION} --name ecommerce-eks"
                    sh "sed -i 's|<IMAGE_TAG>|${IMAGE_TAG}|g' devops/k8s/*.yaml"
                    sh "kubectl apply -f devops/k8s/"
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        success {
            echo 'Pipeline completed successfully!'
        }
        failure {
            echo 'Pipeline failed. Check logs.'
        }
    }
}
